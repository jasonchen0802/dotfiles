#!/usr/bin/env zsh

# +---------+
# | OPTIONS |
# +---------+

source $ZDOTDIR/setopt.zsh

# +------------+
# | COMPLETION |
# +------------+

source $ZDOTDIR/completion.zsh

# +--------+
# | PROMPT |
# +--------+

source $ZDOTDIR/prompt.zsh

# +---------+
# | BINDKEY |
# +---------+

source $ZDOTDIR/binding.zsh

# +---------+
# | ALIASES |
# +---------+

source $XDG_CONFIG_HOME/aliases/aliases
